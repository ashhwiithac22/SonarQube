pipeline {
    agent any

    environment {
        // Use the SonarQube token you already created in Jenkins
        SONAR_TOKEN = credentials('sonar-token')
    }

    stages {
        stage('Checkout') {
            steps {
                echo "Checking out code from GitHub..."
                git branch: 'main', url: 'https://github.com/ashhwiithac22/SonarQube.git'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                echo "Starting SonarQube analysis..."
                withSonarQubeEnv('My Sonar Server') {
                    // Run the scanner with the token from Jenkins credentials
                    sh "/opt/sonar-scanner/bin/sonar-scanner -Dsonar.login=${SONAR_TOKEN} -Dsonar.projectKey=SonarQube-demo -Dsonar.sources=."
                }
            }
        }

        stage('Quality Gate') {
            steps {
                script {
                    echo "Waiting for Quality Gate result..."
                    timeout(time: 5, unit: 'MINUTES') {
                        // This will abort the pipeline if Quality Gate fails
                        def qg = waitForQualityGate(abortPipeline: true)
                        echo "Quality Gate status: ${qg.status}"
                    }
                }
            }
        }
    }

    post {
        success {
            echo "✅ Build SUCCESSFUL and Quality Gate passed!"
        }
        failure {
            echo "❌ Build FAILED due to Quality Gate failure or other errors."
        }
    }
}
