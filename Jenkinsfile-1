pipeline {
    agent any
    
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        
        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv(installationName: 'My Sonar Server') {
                    script {
                        def scannerHome = tool 'SonarScanner'
                        def branchName = env.BRANCH_NAME ?: 'main'  // Get current branch or default to main
                        
                        sh """
                            ${scannerHome}/bin/sonar-scanner \
                            -Dsonar.projectKey=Ex13_A_${JOB_NAME} \
                            -Dsonar.projectName=Exercise13A_Python_Project \
                            -Dsonar.projectVersion=1.0 \
                            -Dsonar.branch.name=${branchName} \
                            -Dsonar.sources=. \
                            -Dsonar.language=py \
                            -Dsonar.sourceEncoding=UTF-8 \
                            -Dsonar.python.version=3 \
                            -Dsonar.exclusions=**/venv/**,**/env/**,**/__pycache__/**
                        """
                    }
                }
            }
        }
        
        stage('Quality Gate') {
            steps {
                timeout(time: 3, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }
    }
    
    post {
        always {
            echo 'SonarQube analysis completed!'
        }
        success {
            echo 'Pipeline succeeded! Check SonarQube dashboard.'
        }
    }
}
