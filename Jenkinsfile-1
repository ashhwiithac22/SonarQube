pipeline {
    agent any
    
    stages {
        stage('Checkout') {
            steps {
                checkout scm
                script {
                    // List files to verify checkout
                    sh 'ls -la'
                }
            }
        }
        
        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv(installationName: 'My Sonar Server') {
                    script {
                        def scannerHome = tool 'SonarScanner'
                        
                        // REMOVED the branch parameter - not needed for Community Edition
                        sh """
                            ${scannerHome}/bin/sonar-scanner \
                            -Dsonar.projectKey=Ex13_A_${JOB_NAME} \
                            -Dsonar.projectName=Exercise13A_Python_Project \
                            -Dsonar.projectVersion=1.0 \
                            -Dsonar.sources=. \
                            -Dsonar.language=py \
                            -Dsonar.sourceEncoding=UTF-8 \
                            -Dsonar.python.version=3 \
                            -Dsonar.exclusions=**/venv/**,**/env/**,**/__pycache__/**
                        """
                    }
                }
            }
        }
        
        stage('Quality Gate') {
            steps {
                script {
                    try {
                        timeout(time: 2, unit: 'MINUTES') {
                            waitForQualityGate abortPipeline: false
                        }
                    } catch (Exception e) {
                        echo "Quality Gate check timed out: ${e.message}"
                    }
                }
            }
        }
    }
    
    post {
        always {
            echo 'SonarQube analysis completed!'
            echo "View results at: http://localhost:9000/dashboard?id=Ex13_A_${JOB_NAME}"
        }
        success {
            echo '✅ Pipeline completed successfully!'
        }
        failure {
            echo '❌ Pipeline failed. Check Jenkins logs for details.'
        }
        cleanup {
            cleanWs()
        }
    }
}
