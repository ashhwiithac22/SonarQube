pipeline {
    agent any

    environment {
        SONARQUBE_HOST_URL = 'http://localhost:9000'
        SONARQUBE_AUTH_TOKEN = 'squ_56448c004d3c95ec04634cea362f9c8039919e60'
    }

    stages {
        stage('Checkout Code') {
            steps {
                echo "Checking out code from GitHub..."
                git branch: 'main',
                    url: 'https://github.com/ashhwiithac22/SonarQube.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                echo "Installing Python dependencies..."
                // No virtual environment, install system-wide
                sh '''
                    sudo apt-get update
                    sudo apt-get install -y python3-pip
                    pip3 install --upgrade pip pytest pytest-cov
                '''
            }
        }

        stage('Run Unit Tests & Coverage') {
            steps {
                sh 'pytest --cov=. --cov-report=xml:coverage.xml'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                sh '''
                    /opt/sonar-scanner/bin/sonar-scanner \
                    -Dsonar.projectKey=Ex16_Clean_as_You_Go \
                    -Dsonar.sources=. \
                    -Dsonar.host.url=$SONARQUBE_HOST_URL \
                    -Dsonar.login=$SONARQUBE_AUTH_TOKEN \
                    -Dsonar.python.coverage.reportPaths=coverage.xml
                '''
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 2, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }
    }

    post {
        always {
            echo "Build finished. Check console output and SonarQube report!"
        }
        success {
            echo "Build SUCCESS - SonarQube Quality Gate passed!"
        }
        failure {
            echo "Build FAILED!"
        }
    }
}
