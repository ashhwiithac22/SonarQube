pipeline {
    agent any
    stages {
        stage('Checkout') {
            steps {
                echo 'Checking out code from GitHub...'
                git url: 'https://github.com/ashhwiithac22/SonarQube.git', branch: 'main'
            }
        }
        stage('Setup Python Environment') {
            steps {
                sh 'python3 -m venv venv'
                sh '. venv/bin/activate && pip install --upgrade pip pytest sonar-python'
            }
        }
        stage('Run Unit Tests') {
            steps {
                sh '. venv/bin/activate && pytest --maxfail=1 --disable-warnings -q'
            }
        }
        stage('SonarQube Analysis') {
            environment {
                SONARQUBE_HOST_URL = 'http://localhost:9000'
                SONARQUBE_AUTH_TOKEN = 'YOUR_SONAR_TOKEN'
            }
            steps {
                sh '. venv/bin/activate && sonar-scanner -Dsonar.projectKey=Ex16_Clean_Code -Dsonar.sources=.'
            }
        }
        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }
    }
}
