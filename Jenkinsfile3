pipeline {
    agent any

    environment {
        SONARQUBE_HOST_URL = 'http://localhost:9000'  // Replace with your SonarQube URL
        SONARQUBE_AUTH_TOKEN = 'squ_56448c004d3c95ec04634cea362f9c8039919e60'  // Your token
        VENV_PATH = "${WORKSPACE}/venv"
    }

    stages {

        stage('Checkout Code') {
            steps {
                echo "Checking out code from GitHub..."
                git branch: 'main',
                    url: 'https://github.com/ashhwiithac22/SonarQube.git'
            }
        }

        stage('Setup Python Environment') {
            steps {
                echo "Creating Python virtual environment and installing dependencies..."
                sh '''
                    python3 -m venv $VENV_PATH
                    source $VENV_PATH/bin/activate
                    pip install --upgrade pip pytest pytest-cov
                '''
            }
        }

        stage('Run Unit Tests & Coverage') {
            steps {
                echo "Running Pytest with coverage..."
                sh '''
                    source $VENV_PATH/bin/activate
                    pytest --cov=. --cov-report=xml:coverage.xml
                '''
            }
        }

        stage('SonarQube Analysis') {
            steps {
                echo "Running SonarScanner analysis..."
                sh '''
                    /opt/sonar-scanner/bin/sonar-scanner \
                        -Dsonar.projectKey=Ex16_Clean_as_You_Go \
                        -Dsonar.sources=. \
                        -Dsonar.host.url=$SONARQUBE_HOST_URL \
                        -Dsonar.login=$SONARQUBE_AUTH_TOKEN \
                        -Dsonar.python.coverage.reportPaths=coverage.xml
                '''
            }
        }

        stage('Quality Gate') {
            steps {
                echo "Checking SonarQube Quality Gate..."
                timeout(time: 2, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }
    }

    post {
        always {
            echo "Cleaning up virtual environment..."
            sh 'rm -rf $VENV_PATH'
        }
        success {
            echo "Build SUCCESS - SonarQube Quality Gate passed!"
        }
        failure {
            echo "Build FAILED - Check console output and SonarQube report!"
        }
    }
}
